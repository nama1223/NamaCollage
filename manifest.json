{
  "name": "NamaCollage",
  "short_name": "ナマコ",
  "description": "複数の画像を縦・横・グリッドに結合するPWAアプリ。",
  "start_url": "./",
  "scope": "./",
  "display": "standalone",
  "orientation": "any",
  "background_color": "#0000FF",
  "theme_color": "#FF6940",
  "lang": "ja",
  "categories": ["photo", "productivity", "utilities"],
  "icons": [
    {
      "src": "./NamaCollageLogo192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "./NamaCollageLogo512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    }
  ],
  "share_target": {
    "action": "./share-target",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "files": [
        {
          "name": "images",
          "accept": ["image/*"]
        }
      ]
    }
  }
}
